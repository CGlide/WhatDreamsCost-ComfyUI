et":{"name":"reference_strength"},"link":null}],"outputs":[{"localized_name":"model","name":"model","type":"MODEL","links":[286,287]},{"localized_name":"positive","name":"positive","type":"CONDITIONING","links":[284,285]},{"localized_name":"video_latent","name":"video_latent","type":"LATENT","links":[283]},{"localized_name":"audio_latent","name":"audio_latent","type":"LATENT","links":[282]},{"localized_name":"guide_data","name":"guide_data","type":"GUIDE_DATA","links":[280,281]},{"localized_name":"frame_rate","name":"frame_rate","type":"FLOAT","links":[279]},{"localized_name":"combined_audio","name":"combined_audio","type":"AUDIO","links":null},{"localized_name":"clean_latent_frames","name":"clean_latent_frames","type":"INT","links":[278]},{"localized_name":"clean_pixel_frames","name":"clean_pixel_frames","type":"INT","links":null}],"properties":{"cnr_id":"whatdreamscost-comfyui","ver":"1.3.9","Node name for S&R":"LTXDirector"},"widgets_values":["A cinematic 8-second sequence in a vast, dark industrial hangar. A character in ornate white armor with gold filigree walks toward a sleek, black futuristic interceptor ship. The hangar floor is damp and reflective, catching the cold overhead lights and the glowing cyan LEDs of the spacecraft. High-fidelity rendering of the carbon-fiber textures of the ship and the mechanical joints of the armor. The atmosphere is heavy with steam and the low-frequency hum of machinery.",192,8,"{\"segments\":[{\"id\":\"17794789797816doy2\",\"start\":20.340175873240582,\"length\":81,\"prompt\":\"Action: The camera begins at a medium-wide angle as the armored character turns and begins to stride toward the black interceptor.\\nDetails: The character is positioned in the foreground right, walking toward the center-left. His heavy, armored boots create sharp, metallic clinks on the concrete floor, sending small ripples through shallow puddles. The camera performs a smooth, cinematic dolly-left, following his movement. As he walks, the gold filigree on his back-plating catches the overhead industrial lights. In the background, the ship’s cyan engine vents begin to pulse with a low blue light.\",\"type\":\"image\",\"imageFile\":\"05-22T19-35-32-736Z_primary.jpg\",\"imageB64\":\"/api/view?filename=05-22T19-35-32-736Z_primary.jpg&type=input&subfolder=\",\"guideStrength\":0.946},{\"id\":\"1779479059297tgoyi\",\"start\":102.34017587324058,\"length\":89.65982412675942,\"prompt\":\"Action: The camera drops to a low-angle tracking shot, moving backward just ahead of the character as he reaches the ship's wing.\\nDetails: The camera focus is sharp on the character’s legs and the reflective floor before racking focus up to his helmet. The black interceptor looms large in the background, its dark glass canopy reflecting the character’s white armor. As he nears the cockpit, he raises a gauntleted hand toward the ship's hull. The cyan lights on the ship transition from a steady glow to a fast flicker. The scene maintains a relentless forward momentum until the character's white-and-gold torso fills the frame.\",\"type\":\"text\"}],\"audioSegments\":[]}",false,"Action: The camera begins at a medium-wide angle as the armored character turns and begins to stride toward the black interceptor.\nDetails: The character is positioned in the foreground right, walking toward the center-left. His heavy, armored boots create sharp, metallic clinks on the concrete floor, sending small ripples through shallow puddles. The camera performs a smooth, cinematic dolly-left, following his movement. As he walks, the gold filigree on his back-plating catches the overhead industrial lights. In the background, the ship’s cyan engine vents begin to pulse with a low blue light. | Action: The camera drops to a low-angle tracking shot, moving backward just ahead of the character as he reaches the ship's wing.\nDetails: The camera focus is sharp on the character’s legs and the reflective floor before racking focus up to his helmet. The black interceptor looms large in the background, its dark glass canopy reflecting the character’s white armor. As he nears the cockpit, he raises a gauntleted hand toward the ship's hull. The cyan lights on the ship transition from a steady glow to a fast flicker. The scene maintains a relentless forward momentum until the character's white-and-gold torso fills the frame.","102.34017587324058,89.65982412675942",0.001,24,"seconds","0.95",1920,1088,"stretch to fit",32,18,true,1,""]},{"id":29,"type":"KSamplerSelect","pos":[3736.805994963843,4508.288648200755],"size":[210,60],"flags":{},"order":17,"mode":0,"inputs":[{"localized_name":"sampler_name","name":"sampler_name","type":"COMBO","widget":{"name":"sampler_name"},"link":null}],"outputs":[{"localized_name":"SAMPLER","name":"SAMPLER","type":"SAMPLER","links":[53]}],"properties":{"cnr_id":"comfy-core","ver":"0.3.56","Node name for S&R":"KSamplerSelect","enableTabs":false,"tabWidth":65,"tabXOffset":10,"hasSecondTab":false,"secondTabText":"Send Back","secondTabOffset":80,"secondTabWidth":65},"widgets_values":["res_2s"]}],"links":[[6,5,0,8,0,"CONDITIONING"],[7,5,1,8,1,"CONDITIONING"],[10,8,0,9,1,"CONDITIONING"],[11,8,1,9,2,"CONDITIONING"],[12,9,0,10,1,"GUIDER"],[14,7,0,10,4,"LATENT"],[50,26,0,5,1,"CONDITIONING"],[51,28,0,10,0,"NOISE"],[52,11,0,10,3,"SIGMAS"],[53,29,0,10,2,"SAMPLER"],[54,8,0,14,0,"CONDITIONING"],[55,8,1,14,1,"CONDITIONING"],[108,8,2,7,0,"LATENT"],[124,49,0,47,1,"GUIDER"],[125,53,0,47,2,"SAMPLER"],[127,50,0,47,4,"LATENT"],[135,55,2,52,0,"LATENT"],[136,48,0,14,2,"LATENT"],[142,13,0,55,2,"LATENT"],[143,13,1,50,1,"LATENT"],[144,57,0,52,1,"LATENT_UPSCALE_MODEL"],[146,55,0,58,0,"CONDITIONING"],[147,55,1,58,1,"CONDITIONING"],[150,52,0,58,3,"LATENT"],[152,58,0,49,1,"CONDITIONING"],[153,58,1,49,2,"CONDITIONING"],[154,58,2,50,0,"LATENT"],[157,28,0,47,0,"NOISE"],[180,47,0,48,0,"LATENT"],[188,8,0,55,0,"CONDITIONING"],[189,8,1,55,1,"CONDITIONING"],[196,78,0,79,2,"VAE"],[197,79,0,80,0,"MODEL"],[212,94,0,79,0,"MODEL"],[213,101,0,95